{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "outDir": "lib",
        "rootDir": "src",
        "sourceMap": true,
        "strict": true,
        "target": "ES2022",
        "lib": ["ES2022"],
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "compileOnSave": true,
    "include": ["src/**/*.ts"]
}
